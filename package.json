{
  "name": "bambu-buddy",
  "version": "0.2.2",
  "description": "Bambu Buddy — 一只熊猫常驻桌面，根据打印机状态播放对应动画",
  "main": "src/main.js",
  "author": "YingyiDai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YingyiDai/bambu-buddy"
  },
  "scripts": {
    "start": "electron .",
    "process-videos": "bash scripts/process-videos.sh",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.1",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.bambubuddy.desktop",
    "productName": "Bambu Buddy",
    "icon": "assets/icon/AppIcon.png",
    "files": [
      "src/**/*",
      "assets/anim/**/*",
      "assets/icon/**",
      "assets/printer/**",
      "assets/image/**",
      "!assets/source/**",
      "!assets/icon/AppIcon.win.png"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**",
      "**/node_modules/@koromix/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Bambu.Buddy-${version}-macOS-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon/AppIcon.ico",
      "artifactName": "Bambu.Buddy-${version}-Windows-${arch}.Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterSign": "build/adhoc-sign.js",
    "afterAllArtifactBuild": "build/notarize-dmg.js",
    "publish": {
      "provider": "github"
    }
  }
}
